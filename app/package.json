{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --mode e2e",
    "build:site": "vite build && node --import tsx scripts/generate-site-files.ts",
    "build": "npm run typecheck && npm run build:site",
    "preview": "vite preview",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "typecheck": "vue-tsc -b",
    "lint": "eslint --cache --cache-location .eslintcache --max-warnings=0 \"src/**/*.{ts,tsx,vue}\" \"e2e/**/*.ts\" vite.config.ts playwright.config.ts playwright.visual.config.ts playwright.demo.config.ts playwright.readme-gif.config.ts playwright.readme-cli.config.ts eslint.config.mjs",
    "lint:fix": "eslint --cache --cache-location .eslintcache --fix \"src/**/*.{ts,tsx,vue}\" \"e2e/**/*.ts\" vite.config.ts playwright.config.ts playwright.visual.config.ts playwright.demo.config.ts playwright.readme-gif.config.ts playwright.readme-cli.config.ts eslint.config.mjs",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.thresholds.perFile=true --coverage.thresholds.statements=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80 --coverage.thresholds.lines=80",
    "e2e": "playwright test",
    "a11y": "playwright test e2e/a11y.spec.ts",
    "visual": "playwright test -c playwright.visual.config.ts",
    "visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "e2e:headed": "playwright test --headed",
    "demo:record": "playwright test e2e/demo-walkthrough.spec.ts -c playwright.demo.config.ts",
    "readme:video": "playwright test e2e/readme-gif-walkthrough.spec.ts -c playwright.readme-gif.config.ts && node ../scripts/readme-video-convert.mjs",
    "e2e:install": "playwright install chromium",
    "verify": "npm run lint && npm run coverage && npm run build && npm run e2e && npm run a11y && npm run visual",
    "verify:ci": "npm run lint && npm run build && npm run e2e && npm run a11y && npm run visual"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/roboto-mono": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.4",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
