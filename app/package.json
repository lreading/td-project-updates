{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "validate:content": "tsx scripts/validate-content.ts",
    "typecheck": "vue-tsc -b",
    "lint": "eslint --cache --cache-location .eslintcache --max-warnings=0 \"src/**/*.{ts,tsx,vue}\" \"e2e/**/*.ts\" vite.config.ts playwright.config.ts eslint.config.mjs",
    "lint:fix": "eslint --cache --cache-location .eslintcache --fix \"src/**/*.{ts,tsx,vue}\" \"e2e/**/*.ts\" vite.config.ts playwright.config.ts eslint.config.mjs",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.thresholds.perFile=true --coverage.thresholds.statements=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80 --coverage.thresholds.lines=80",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/roboto-mono": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
